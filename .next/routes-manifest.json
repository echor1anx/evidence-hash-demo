    {
      "page": "/api/auth/logout",
      "regex": "^/api/auth/logout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/logout(?:/)?$"
    },
    {
      "page": "/api/auth/me",
      "regex": "^/api/auth/me(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/me(?:/)?$"
    },
    {
      "page": "/api/auth/register",
      "regex": "^/api/auth/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/register(?:/)?$"
    },
    {
      "page": "/api/cases",
      "regex": "^/api/cases(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/cases(?:/)?$"
    },
    {
      "page": "/api/custody",
      "regex": "^/api/custody(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/custody(?:/)?$"
    },
    {
      "page": "/api/upload",
      "regex": "^/api/upload(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/upload(?:/)?$"
    },
    {
      "page": "/api/users/investigators",
      "regex": "^/api/users/investigators(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/users/investigators(?:/)?$"
    },
    {
      "page": "/cases",
      "regex": "^/cases(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cases(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/cases/new",
      "regex": "^/dashboard/cases/new(?:/)?$",
