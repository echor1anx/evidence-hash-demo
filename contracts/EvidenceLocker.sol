    // --- Core Functions ---

    /**
     * @dev Registers a new piece of evidence onto the blockchain.
     */
    function registerEvidence(
        string memory _evidenceId, 
        string memory _caseId, 
        string memory _fileHash,
        string memory _ipfsCID
    ) public {
        require(bytes(evidenceLedger[_evidenceId].evidenceId).length == 0, "Evidence ID already exists");

        evidenceLedger[_evidenceId] = Evidence({
            evidenceId: _evidenceId,
            caseId: _caseId,
            fileHash: _fileHash,
            ipfsCID: _ipfsCID,
            timestamp: block.timestamp,
            currentHolder: msg.sender,
            status: "Registered",
            accessCount: 0
        });

        caseToEvidence[_caseId].push(_evidenceId);

        chainOfCustody[_evidenceId].push(CustodyLog({
            from: address(0),
            to: msg.sender,
            timestamp: block.timestamp,
            action: "Initial Registration",
            note: "Uploaded"
        }));

        emit EvidenceUploaded(_evidenceId, _fileHash, _ipfsCID, msg.sender, block.timestamp);
    }

    /**
     * @dev Modify an existing piece of evidence (e.g. replacing the file)
     */
    function modifyEvidence(
        string memory _evidenceId,
        string memory _newHash,
        string memory _newIpfsCID,
        string memory _note
    ) public {
        Evidence storage ev = evidenceLedger[_evidenceId];
        require(bytes(ev.evidenceId).length != 0, "Evidence does not exist");
        
        ev.fileHash = _newHash;
        ev.ipfsCID = _newIpfsCID;
        ev.timestamp = block.timestamp;
        ev.status = "Modified";

        chainOfCustody[_evidenceId].push(CustodyLog({
            from: ev.currentHolder,
            to: msg.sender,
            timestamp: block.timestamp,
            action: "Modified",
            note: _note
        }));

        emit EvidenceModified(_evidenceId, _newHash, _newIpfsCID, msg.sender, block.timestamp, _note);
    }

    /**
     * @dev Log an access event to the evidence
     */
    function accessEvidence(string memory _evidenceId) public {
        Evidence storage ev = evidenceLedger[_evidenceId];
        require(bytes(ev.evidenceId).length != 0, "Evidence does not exist");
        
        ev.accessCount += 1;
        userAccessCount[_evidenceId][msg.sender] += 1;
        
        emit EvidenceAccessed(_evidenceId, msg.sender, block.timestamp, userAccessCount[_evidenceId][msg.sender]);
    }

    /**
     * @dev Grant access to a specific address for an evidence item
     */
    function grantAccess(string memory _evidenceId, address _to) public {
        Evidence storage ev = evidenceLedger[_evidenceId];
        require(bytes(ev.evidenceId).length != 0, "Evidence does not exist");
        
        accessPermissions[_evidenceId][_to] = true;
        
        emit AccessGranted(_evidenceId, _to, msg.sender, block.timestamp);
    }

    /**
     * @dev Transfers custody of evidence
     */
    function transferCustody(
        string memory _evidenceId, 
        address _newHolder, 
        string memory _actionDetails
    ) public {
        Evidence storage ev = evidenceLedger[_evidenceId];
        require(bytes(ev.evidenceId).length != 0, "Evidence does not exist");
        require(msg.sender == ev.currentHolder, "Only holder can transfer");

        ev.currentHolder = _newHolder;
        ev.status = "In Transfer";

        chainOfCustody[_evidenceId].push(CustodyLog({
            from: msg.sender,
            to: _newHolder,
            timestamp: block.timestamp,
            action: _actionDetails,
            note: ""
        }));

        emit CustodyTransferred(_evidenceId, msg.sender, _newHolder, _actionDetails);
    }

    function getEvidenceData(string memory _evidenceId) public view returns (Evidence memory) {
        return evidenceLedger[_evidenceId];
    }

    function getChainOfCustodyData(string memory _evidenceId) public view returns (CustodyLog[] memory) {
        return chainOfCustody[_evidenceId];
    }
}
