pragma solidity ^0.8.20;

/**
 * @title EvidenceLocker
 * @dev Implements an immutable chain of custody for digital evidence using cryptographic hashes.
 *      Stores evidence metadata on-chain with IPFS CIDs for decentralized file storage.
 */
contract EvidenceLocker {

    // --- Roles ---
    address public admin;
    mapping(address => bool) public investigators;

    // --- Structs ---
    struct Evidence {
        string evidenceId;      // e.g. "EV-0X889"
        string caseId;          // e.g. "CAS-2026-8921"
        string fileHash;        // SHA-256 fingerprint generated by the client
        string ipfsCID;         // IPFS Content Identifier for the file
        uint256 timestamp;      // Block timestamp of registration
        address currentHolder;  // The user currently holding the physical/digital evidence
        string status;          // "Registered", "Modified", "In Custody"
        uint256 accessCount;    // Track total number of accesses
    }

    struct CustodyLog {
        address from;
        address to;
        uint256 timestamp;
        string action;          // e.g., "Modified", "Transferred"
        string note;
    }

    // --- State Variables ---
    mapping(string => Evidence) public evidenceLedger;
    mapping(string => CustodyLog[]) public chainOfCustody;
    mapping(string => string[]) public caseToEvidence;
    
    // Per-user access count for each evidence item
    mapping(string => mapping(address => uint256)) public userAccessCount;
    
    // Access permissions - which addresses are granted access to which evidence
    mapping(string => mapping(address => bool)) public accessPermissions;

    // --- Events ---
    event EvidenceUploaded(
        string indexed evidenceId, 
        string fileHash, 
        string ipfsCID, 
        address indexed uploaderAddress, 
        uint256 timestamp
    );
    
    event EvidenceModified(
        string indexed evidenceId, 
        string newHash, 
        string newIpfsCID, 
        address indexed modifierAddress, 
        uint256 timestamp, 
        string note
    );
    
    event AccessGranted(
        string indexed evidenceId, 
        address indexed grantedTo, 
        address indexed grantedBy, 
        uint256 timestamp
    );
    
    event EvidenceAccessed(
        string indexed evidenceId, 
        address indexed accessorAddress, 
        uint256 timestamp, 
        uint256 accessCountForUser
    );
    
    event CustodyTransferred(
        string indexed evidenceId, 
        address indexed from, 
        address indexed to, 
        string action
    );

    // --- Modifiers ---
    modifier onlyAdmin() {
        require(msg.sender == admin, "Caller is not an Admin");
        _;
    }

